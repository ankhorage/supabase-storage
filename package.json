{
  "name": "@ankhorage/supabase-storage",
  "type": "module",
  "version": "0.1.0",
  "description": "Type-safe Supabase Storage adapter for uploads, public URLs, and asset metadata.",
  "homepage": "https://github.com/ankhorage/supabase-storage#readme",
  "bugs": {
    "url": "https://github.com/ankhorage/supabase-storage/issues"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ankhorage/supabase-storage.git"
  },
  "keywords": [
    "typescript",
    "supabase",
    "storage",
    "file-upload",
    "adapter",
    "assets"
  ],
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3"
  },
  "files": [
    "dist",
    "src",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && bun x tsc -p tsconfig.json",
    "changeset": "changeset",
    "changeset:status": "changeset status --since=origin/main",
    "knip": "knip",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepack": "bun run build",
    "test": "bun test src",
    "typecheck": "bun x tsc --noEmit -p tsconfig.json",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@ankhorage/devtools": "^1.0.1",
    "@ankhorage/paradox": "^0.0.9",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "knip": "^5.88.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.13"
}
